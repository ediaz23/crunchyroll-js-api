{
    "compilerOptions": {
        "resolveJsonModule": true,
        "allowJs": true,
        "checkJs": true,
        "emitDeclarationOnly": true,
        "declaration": true,
        "esModuleInterop": true,
        "strictNullChecks": false,
        "noImplicitAny": false,
        "declarationDir": "./dist/types",
        "rootDir": "./src",
        "types": [
            "node"
        ],
    },
    "include": [
        "src/*.js",
        "src/**/*.js"
    ],
    "exclude": [
        "node_modules"
    ]
}